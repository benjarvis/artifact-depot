{
	"name": "artifact-depot",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"DOCKER_MIRROR": "",
			"APT_MIRROR": ""
		}
	},
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"anthropic.claude-code"
			]
		}
	},
	"initializeCommand": "mkdir -p \"${localEnv:HOME}${localEnv:USERPROFILE}/.claude\"",
	"mounts": [
		"source=artifact-depot-worktrees,target=/worktrees,type=volume",
		"source=artifact-depot-build,target=/build,type=volume"
	],
	"appPort": [],
	"forwardPorts": [4000, 8080],
	"portsAttributes": {
		"4000": {
			"label": "Jekyll docs (make docs-serve)",
			"onAutoForward": "openBrowser"
		},
		"8080": {
			"label": "Depot server (make demo)",
			"onAutoForward": "notify"
		}
	},
	"privileged": true,
	"workspaceMount": "source=${localWorkspaceFolder},target=/artifact-depot,type=bind",
	"workspaceFolder": "/artifact-depot"
}
