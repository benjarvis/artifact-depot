# AWS credentials -- used by depot for DynamoDB and by the init container
# to create the S3 blob store.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# S3 bucket for depot blob storage (must already exist in your AWS account)
DEPOT_S3_BUCKET=my-depot-blobs

# Depot admin password (must match depotd.toml default_admin_password)
DEPOT_ADMIN_PASSWORD=admin

# MinIO credentials (local object storage for OTel backends)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
