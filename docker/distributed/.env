GARAGE_ACCESS_KEY=GK0123456789abcdef0123
GARAGE_SECRET_KEY=abcdef0123456789abcdef0123456789abcdef01

# MinIO credentials (OTel storage backend)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# Depot admin password (must match depotd.toml default_admin_password)
DEPOT_ADMIN_PASSWORD=admin
